{
  "manifest_version": 3,
  "name": "NYT Connections Helper",
  "description": "Cycle NYT Connections tiles through customizable category colors and manage settings from a popup or options page.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.nytimes.com/games/connections*",
        "https://www.nytimes.com/crosswords/game/connections*"
      ],
      "js": [
        "src/shared/defaults.js",
        "src/content/main.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "NYT Connections Helper"
  },
  "options_page": "src/options/options.html"
}
