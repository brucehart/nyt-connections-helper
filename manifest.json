{
  "manifest_version": 3,
  "name": "NYT Connections Helper",
  "description": "Unofficial NYT Connections helper, not affiliated with The New York Times, with local-only category settings.",
  "version": "0.1",
  "homepage_url": "https://github.com/brucehart/nyt-connections-helper/blob/main/PRIVACY.md",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.nytimes.com/games/connections*",
        "https://www.nytimes.com/crosswords/game/connections*"
      ],
      "js": [
        "src/shared/defaults.js",
        "src/content/main.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "src/popup/popup.html",
    "default_title": "NYT Connections Helper"
  },
  "options_page": "src/options/options.html"
}
